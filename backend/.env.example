# ============================================================
# OK.station — Variables de entorno
# Copia este archivo como  .env  y complétalo en CloudPanel.
# .env NUNCA se sube al repositorio (ver .gitignore).
# ============================================================

# ── Base de datos ──
DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_NAME=okstation
DB_USER=okstation_user
DB_PASS=CAMBIA_ESTO

# ── Seguridad (JWT) ──
# Genera: php -r "echo bin2hex(random_bytes(48));"
JWT_SECRET=CAMBIA_ESTA_CLAVE_POR_UNA_LARGA_Y_ALEATORIA
JWT_TTL=604800

# ── App ──
APP_URL=https://okstation.mx
APP_ENV=production            # production | development
CORS_ORIGIN=https://okstation.mx

# ── Administradores "bootstrap" ──
# Correos que recibirán el rol 'administrador' al registrarse.
# NO se usan en la lógica como correos fijos: solo siembran el primer
# admin; después se gestionan por rol desde la BD/panel.
ADMIN_EMAILS=tucorreo@okstation.mx

# ── Almacenamiento de archivos subidos ──
# Ruta absoluta fuera de la raíz pública (CloudPanel). Debe existir y ser escribible.
STORAGE_PATH=/home/okstation/storage/uploads
MAX_UPLOAD_MB=25
