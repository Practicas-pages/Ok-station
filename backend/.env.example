# ============================================================
# OK.station — Variables de entorno (PRODUCCIÓN)
# Copia este archivo como  .env  y complétalo en CloudPanel.
# .env NUNCA se sube al repositorio (ver .gitignore).
# Nunca se colocan credenciales dentro del código: TODO sale de aquí.
# ============================================================

# ── Base de datos ──
DATABASE_HOST=127.0.0.1
DATABASE_PORT=3306
DATABASE_NAME=
DATABASE_USER=
DATABASE_PASSWORD=

# ── Aplicación ──
APP_URL=https://okstation.mx
APP_ENV=production              # production | development
CORS_ORIGIN=https://okstation.mx

# ── Seguridad (JWT) ──
# Genera uno con: php -r "echo bin2hex(random_bytes(48));"
JWT_SECRET=
JWT_TTL=604800                  # 7 días en segundos

# ── Administradores "bootstrap" ──
# Correos que reciben el rol 'administrador' al registrarse.
# Después se gestionan por rol en la BD/panel (no se usan como correos fijos en el código).
ADMIN_EMAILS=

# ── Correo SMTP (recuperación de contraseña, notificaciones) ──
SMTP_HOST=
SMTP_PORT=587                   # 587 STARTTLS (recomendado) | 465 SSL
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=no-reply@okstation.mx
SMTP_FROM_NAME=OK.station

# ── Almacenamiento de archivos (PDFs de clientes, imágenes, tickets) ──
# Ruta ABSOLUTA, idealmente FUERA de la raíz pública del sitio.
# En CloudPanel suele ser algo como: /home/<sitio>/storage
STORAGE_PATH=/home/okstation/storage
MAX_UPLOAD_MB=25
